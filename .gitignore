# -----------------------------------------------------------------------------
# Only the following are committed (everything needed to recreate the project):
#   configs/, src/, scripts/, docker/, assets/, docs/
#   README.md, LICENSE, pyproject.toml, requirements.txt, Makefile, .gitignore
# Recreate data + runs by running: 00 → 01 → 02 → 03 → 05 → 06 → 07...
# -----------------------------------------------------------------------------

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
dist/
build/
eggs/
.eggs/
.venv/
.uv/
venv/
env/
.pytest_cache/
.coverage
htmlcov/
*.manifest

# Data and runs (regenerated by pipeline)
data/
runs/

# HuggingFace / model cache (downloaded on first run)
*.bin
*.safetensors
hf_cache/

# OS
.DS_Store
Thumbs.db
*.swp
*~

# IDE / editor
.idea/
.vscode/
*.sublime-*

# Env and secrets
.env
.env.*
!.env.example

# Backup / temp
*.bak
*.tmp
*.log
